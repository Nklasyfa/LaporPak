# ─────────────────────────────────────────────────────────────
# LaporAman — Environment Variables
# Copy file ini ke .env (jangan commit ke git!)
# ─────────────────────────────────────────────────────────────

# Supabase PostgreSQL Connection String
# Ambil dari: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Flask Secret Key (ganti dengan random string yang panjang!)
SECRET_KEY=ganti_dengan_random_string_yang_sangat_panjang_dan_aman
